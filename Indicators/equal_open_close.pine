//@version=6
indicator("Equal Open-Close", shorttitle="EqOC", overlay=true, max_labels_count=500)

// ============================================================================
// SETTINGS
// ============================================================================

i_tolerance = input.float(0.0, "Price Tolerance", minval=0.0, step=0.01, tooltip="Max allowed difference between open[1] and close. 0 = exact match.", group="Detection")
// ============================================================================
// DETECTION
// ============================================================================

// 3-candle OCO: candle[2] open == candle[1] close == candle[0] open
match_oco = math.abs(open[2] - close[1]) <= i_tolerance and math.abs(close[1] - open) <= i_tolerance

// 3-candle COC: candle[2] close == candle[1] open == candle[0] close
match_coc = math.abs(close[2] - open[1]) <= i_tolerance and math.abs(open[1] - close) <= i_tolerance

// First candle color (for OCO pattern)
is_green = close[2] > open[2]
is_red = close[2] < open[2]

// First candle color (for COC pattern)
coc_is_green = close[2] > open[2]
coc_is_red = close[2] < open[2]

// ============================================================================
// DISPLAY
// ============================================================================

// OCO pattern: triangles
plotshape(match_oco and is_green, title="OCO Green", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, offset=-2)
plotshape(match_oco and is_red, title="OCO Red", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, offset=-2)

// COC pattern: diamonds
plotshape(match_coc and coc_is_green, title="COC Green", style=shape.diamond, location=location.belowbar, color=color.lime, size=size.small, offset=-2)
plotshape(match_coc and coc_is_red, title="COC Red", style=shape.diamond, location=location.abovebar, color=color.maroon, size=size.small, offset=-2)

// ============================================================================
// ALERTS
// ============================================================================

oco_alert_msg = match_oco and is_red ? "EqOC-OCO: SHORT ({{ticker}} {{interval}})" : "EqOC-OCO: LONG ({{ticker}} {{interval}})"
if match_oco
    alert(oco_alert_msg, alert.freq_once_per_bar)

coc_alert_msg = match_coc and coc_is_red ? "EqOC-COC: SHORT ({{ticker}} {{interval}})" : "EqOC-COC: LONG ({{ticker}} {{interval}})"
if match_coc
    alert(coc_alert_msg, alert.freq_once_per_bar)

// Alert marks on 3rd candle (where alert fires)
plotshape(match_oco, title="OCO Alert Mark", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny)
plotshape(match_coc, title="COC Alert Mark", style=shape.square, location=location.abovebar, color=color.purple, size=size.tiny)

// ============================================================================
// DEBUG: show prices on matched candles
// ============================================================================

if match_oco
    atr = ta.atr(14)
    label.new(bar_index, high + atr * 2, "OCO\nO[2]:" + str.tostring(open[2]) + "\nC[1]:" + str.tostring(close[1]) + "\nO:" + str.tostring(open), style=label.style_label_down, color=color.gray, textcolor=color.white, size=size.normal)

if match_coc
    atr = ta.atr(14)
    label.new(bar_index, high + atr * 2, "COC\nC[2]:" + str.tostring(close[2]) + "\nO[1]:" + str.tostring(open[1]) + "\nC:" + str.tostring(close), style=label.style_label_down, color=color.purple, textcolor=color.white, size=size.normal)
